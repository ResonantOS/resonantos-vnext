{
  "sdkVersion": "0.1.0",
  "id": "addon.audio2tol",
  "name": "Audio2TOL",
  "version": "0.1.0",
  "author": "Resonant Alpha",
  "category": "tool",
  "description": "Structured TOL pipeline add-on for audio import, transcription, analysis, and bundle emission into Living Archive intake.",
  "runtimeType": "local-service",
  "surfaces": [
    {
      "id": "audio2tol-page",
      "type": "page",
      "label": "Audio2TOL Console",
      "description": "Control the TOL processing pipeline.",
      "shellNavigation": {
        "sectionId": "audio2tol",
        "dockIcon": "audio2tol",
        "eyebrow": "TOL",
        "order": 70
      }
    },
    {
      "id": "audio2tol-monitor",
      "type": "background-task-monitor",
      "label": "Pipeline Monitor",
      "description": "View audio ingestion and processing status."
    }
  ],
  "requestedCapabilities": [
    {
      "capability": "filesystem",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "archive-read",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "degrade"
    },
    {
      "capability": "archive-intake-write",
      "granted": false,
      "scope": "intake-only",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "providers",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "degrade"
    },
    {
      "capability": "shell",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "network",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "degrade"
    },
    {
      "capability": "device-integration",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "degrade"
    }
  ],
  "provenance": {
    "tier": "curated-signed",
    "verificationState": "verified",
    "signed": true,
    "signer": "ResonantOS alpha catalog"
  },
  "runtimeIsolation": {
    "boundary": "host-mediated-service",
    "supportsDegradedMode": true,
    "requiresReviewedGrant": true
  },
  "grantPresets": [
    {
      "id": "audio2tol-intake-workflow",
      "label": "Audio2TOL intake workflow",
      "description": "Allow Audio2TOL to read mapped TOL folders, use provider routes for analysis policy, and queue completed bundles into Living Archive intake.",
      "grants": [
        {
          "capability": "filesystem",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "archive-read",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "degrade"
        },
        {
          "capability": "archive-intake-write",
          "granted": true,
          "scope": "intake-only",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "providers",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "degrade"
        },
        {
          "capability": "shell",
          "granted": true,
          "scope": "system",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "network",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "degrade"
        }
      ]
    }
  ],
  "providerRequirements": {
    "sharedProfiles": ["gx10-local-llama", "shared-openai", "shared-local"],
    "supportsPrivateCredentials": true,
    "recommendedPrimaryModel": "gpt-5.5"
  },
  "archiveIntegration": {
    "readScopes": ["constitution", "protocols", "living-archive/context"],
    "intakeWriteScopes": ["LivingArchive/INTAKE/audio2tol"],
    "canRequestIngest": true,
    "canWriteKnowledgePages": false
  },
  "workflowBoundaries": [
    {
      "id": "audio-to-tol-intake",
      "label": "Audio to TOL intake",
      "jobToBeDone": "Convert TOL audio sessions into structured transcript, analysis, rendered note, and metadata bundles for Living Archive intake.",
      "userValue": "The human can preserve raw audio while the AI receives a structured bundle that is faster and safer to ingest.",
      "repeatability": "workflow-package",
      "owner": "addon-agent",
      "nonGoals": [
        "Overwrite trusted AI Memory pages directly",
        "Discard raw audio or transcript provenance",
        "Run doctrine-sensitive interpretation without the selected provider policy"
      ]
    }
  ],
  "service": {
    "protocol": "host-command",
    "entrypoint": "archive.audio2tol",
    "healthCommand": "audio2tol.bundle_preflight"
  },
  "tools": [
    {
      "name": "audio2tol.detect_bundles",
      "description": "Detect completed and partial Audio2TOL sessions from the mapped TOL raw audio, transcript, and analysis folders.",
      "requiredCapabilities": ["filesystem", "archive-read"],
      "inputSchema": { "type": "object", "additionalProperties": false },
      "outputSchema": { "type": "object" },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["diagnostic-report"]
      }
    },
    {
      "name": "audio2tol.build_bundle",
      "description": "Build a reviewable Living Archive intake bundle for one completed Audio2TOL session.",
      "requiredCapabilities": ["filesystem", "archive-read", "archive-intake-write"],
      "inputSchema": {
        "type": "object",
        "required": ["sessionId"],
        "properties": {
          "sessionId": { "type": "string" }
        },
        "additionalProperties": false
      },
      "outputSchema": { "type": "object" },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["archive-intake-bundle", "log"]
      },
      "requiresHumanApproval": true
    },
    {
      "name": "audio2tol.bundle_preflight",
      "description": "Verify that at least one complete TOL bundle is detectable before archive intake runs.",
      "requiredCapabilities": ["filesystem", "archive-read"],
      "inputSchema": { "type": "object", "additionalProperties": false },
      "outputSchema": { "type": "object" },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["verification-report"]
      }
    },
    {
      "name": "audio2tol.audit",
      "description": "Audit the configured Audio2TOL workflow boundary, mapped folders, and bundle readiness without executing transcription or provider analysis.",
      "requiredCapabilities": ["filesystem", "archive-read"],
      "inputSchema": { "type": "object", "additionalProperties": false },
      "outputSchema": { "type": "object" },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["diagnostic-report", "verification-report"]
      }
    }
  ],
  "skills": [
    {
      "id": "tol-bundle-preparation",
      "name": "TOL bundle preparation",
      "description": "Prepare TOL source bundles with raw audio, transcript, protocol analysis, rendered note, and processing metadata.",
      "documentPath": "docs/architecture/addon-skills/audio2tol/TOL_BUNDLE_PREPARATION.md",
      "invocation": "agent-suggested",
      "requiredCapabilities": ["filesystem", "archive-read", "archive-intake-write", "providers"],
      "requiredTools": ["audio2tol.detect_bundles", "audio2tol.build_bundle", "audio2tol.bundle_preflight"]
    }
  ],
  "augmentorSkills": [
    {
      "documentPath": "docs/architecture/addon-skills/audio2tol/TOL_BUNDLE_PREPARATION.md",
      "objective": "Use Audio2TOL output as a reviewable source bundle for Living Archive intake while preserving raw audio, transcript, derived analysis, and human-directive boundaries.",
      "requiredCapabilities": ["filesystem", "archive-read", "archive-intake-write", "providers"],
      "requiredTools": ["audio2tol.detect_bundles", "audio2tol.build_bundle", "audio2tol.bundle_preflight"],
      "workflowPhases": [
        "Detect candidate TOL sessions",
        "Verify complete raw audio, transcript, and analysis artifacts",
        "Queue one reviewable Living Archive intake bundle per approved session",
        "Route trusted promotion through archive review"
      ],
      "approvalGates": [
        "Human approval before queueing archive intake",
        "Human review before promoting derived directives into trusted memory"
      ],
      "expectedInputs": ["Mapped TOL vault folders", "Audio2TOL transcript and analysis artifacts", "Selected provider policy"],
      "expectedOutputs": ["Archive intake bundle", "Ingest review request", "Verification report"],
      "producesDelegationPackets": false,
      "auditLogRequired": true
    }
  ],
  "connectors": [
    {
      "id": "audio-source-folder",
      "name": "Audio source folder",
      "type": "filesystem",
      "description": "Reads user-selected audio and analysis folders for structured TOL intake preparation.",
      "requiredCapabilities": ["filesystem"],
      "configScope": "user-config"
    }
  ],
  "scripts": [
    {
      "id": "audio2tol-bundle-preflight",
      "name": "Audio2TOL bundle preflight",
      "description": "Verify that required raw, transcript, analysis, note, and metadata files are present before intake.",
      "commandRef": "audio2tol.bundle_preflight",
      "runPolicy": "preflight",
      "deterministic": true,
      "requiredCapabilities": ["filesystem", "archive-read"],
      "producesArtifacts": ["verification-report", "archive-intake-bundle"],
      "requiresHumanApproval": false
    }
  ],
  "hooks": [
    {
      "id": "tol-before-archive-ingest",
      "event": "before-archive-ingest",
      "handlerRef": "audio2tol-bundle-preflight",
      "requiredCapabilities": ["filesystem", "archive-read"],
      "failurePolicy": "block"
    }
  ],
  "engineerSetup": {
    "documentPath": "docs/architecture/addon-runbooks/audio2tol/ENGINEER_SETUP.md",
    "objective": "Connect the standalone Audio2TOL workflow to ResonantOS vNext through mapped folders, host-mediated bundle detection, and Living Archive intake preflight.",
    "requiredCapabilities": ["filesystem", "archive-read", "archive-intake-write", "providers"],
    "allowedHostCommands": ["audio2tol.detect_bundles", "audio2tol.bundle_preflight", "audio2tol.build_bundle"],
    "expectedInputs": ["Audio2TOL app path or existing output folders", "ResonantOS vault mapping", "Provider profile selection"],
    "expectedOutputs": ["Detected bundle candidates", "Passing preflight artifact", "Queued intake bundle after approval"],
    "requiresHumanApprovalBeforeExecution": true,
    "auditLogRequired": true
  },
  "install": {
    "mode": "detect-existing-only",
    "detectionTool": "audio2tol.audit",
    "requiredCapabilities": ["filesystem", "archive-read"],
    "requiresHumanApprovalBeforeInstall": false,
    "preservesExistingUserConfig": true,
    "credentialSetup": "user-guided",
    "auditLogRequired": true,
    "expectedArtifacts": ["diagnostic-report", "verification-report"]
  },
  "audit": {
    "tool": "audio2tol.audit",
    "checks": ["mapped-folders", "candidate-detection", "bundle-readiness", "archive-boundary"],
    "requiredCapabilities": ["filesystem", "archive-read"],
    "remediationPolicy": "suggest-only",
    "auditLogRequired": true
  },
  "memoryAccess": {
    "archiveReadMode": "retrieval-with-citations",
    "archiveWriteMode": "intake-only",
    "citationRequired": true,
    "directKnowledgeWriteAllowed": false
  },
  "smokeTests": [
    {
      "id": "detect-ready-tol-bundles",
      "tool": "audio2tol.bundle_preflight",
      "input": {},
      "expectedOutputPattern": "ready",
      "timeoutMs": 10000,
      "requiredCapabilities": ["filesystem", "archive-read"]
    }
  ],
  "health": {
    "strategy": "pipeline-heartbeat"
  },
  "installHooks": {
    "onInstall": "register-pipeline",
    "onEnable": "start-local-service"
  },
  "compatibility": {
    "shellVersion": "^0.1.0",
    "platforms": ["macOS"]
  }
}
