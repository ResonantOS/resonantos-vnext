{
  "id": "addon.living-archive",
  "name": "Living Archive",
  "version": "0.1.0",
  "author": "Resonant Alpha",
  "category": "memory",
  "sdkVersion": "0.1.0",
  "description": "Recommended default memory-system add-on for ResonantOS. It manages Human Knowledge, External Knowledge, and AI Memory through host-mediated scoped APIs and can be disabled or replaced by another memory add-on.",
  "runtimeType": "local-service",
  "surfaces": [
    {
      "id": "living-archive-workspace",
      "type": "page",
      "label": "Memory Workspace",
      "description": "Configure sources, inspect intake, review memory operations, and manage the active memory provider."
    },
    {
      "id": "living-archive-review",
      "type": "panel",
      "label": "Review Queue",
      "description": "Review memory intake and promotion requests before trusted writes."
    }
  ],
  "requestedCapabilities": [
    {
      "capability": "memory-provider",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "filesystem",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "providers",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "degrade"
    },
    {
      "capability": "archive-read",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "archive-intake-write",
      "granted": false,
      "scope": "intake-only",
      "revocationBehavior": "hard-stop"
    }
  ],
  "provenance": {
    "tier": "curated-signed",
    "verificationState": "verified",
    "signed": true,
    "signer": "ResonantOS bundled catalog"
  },
  "runtimeIsolation": {
    "boundary": "host-mediated-service",
    "supportsDegradedMode": true,
    "requiresReviewedGrant": true
  },
  "grantPresets": [
    {
      "id": "recommended-memory-system",
      "label": "Recommended memory system",
      "description": "Enable Living Archive as the default memory provider with filesystem, provider, read, and intake-write access mediated by the host.",
      "grants": [
        {
          "capability": "memory-provider",
          "granted": true,
          "scope": "system",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "filesystem",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "providers",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "degrade"
        },
        {
          "capability": "archive-read",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "archive-intake-write",
          "granted": true,
          "scope": "intake-only",
          "revocationBehavior": "hard-stop"
        }
      ]
    }
  ],
  "systemSlots": [
    {
      "id": "memory-system",
      "role": "default-provider",
      "replaceable": true,
      "requiredForFirstRun": false,
      "recommended": true
    }
  ],
  "providerRequirements": {
    "sharedProfiles": ["shared-openai", "gx10-local-llama", "shared-minimax", "shared-local"],
    "supportsPrivateCredentials": true,
    "recommendedPrimaryModel": "gpt-5.5",
    "recommendedFallbackModel": "MiniMax-M2.7",
    "preferredRuntimeKinds": ["cloud", "remote-user-owned", "local"],
    "allowExperimentalAuth": true,
    "fallbackPolicyId": "chain-archive-premium"
  },
  "archiveIntegration": {
    "readScopes": ["active-memory/context", "system-memory/context"],
    "intakeWriteScopes": ["Memory/INTAKE"],
    "canRequestIngest": true,
    "canWriteKnowledgePages": false
  },
  "workflowBoundaries": [
    {
      "id": "llm-wiki-memory-system",
      "label": "LLM Wiki memory system",
      "jobToBeDone": "Maintain a replaceable AI-managed memory layer over human-owned and external source collections.",
      "userValue": "The human keeps original knowledge intact while AI-curated memory compounds through intake, review, indexing, linking, and synthesis.",
      "repeatability": "workflow-package",
      "owner": "augmentor",
      "nonGoals": [
        "Mutate original human source material silently",
        "Let ordinary add-ons write trusted knowledge pages directly",
        "Lock ResonantOS to one memory provider forever"
      ]
    }
  ],
  "skills": [
    {
      "id": "source-to-wiki-intake",
      "name": "Source to wiki intake",
      "description": "Classify sources, preserve provenance, create intake artifacts, and prepare AI Memory updates through reviewed promotion.",
      "documentPath": "docs/architecture/addon-skills/living-archive/SOURCE_TO_WIKI_INTAKE.md",
      "invocation": "automatic",
      "requiredCapabilities": ["memory-provider", "filesystem", "providers", "archive-read", "archive-intake-write"],
      "requiredTools": []
    }
  ],
  "connectors": [
    {
      "id": "managed-memory-root",
      "name": "Managed memory root",
      "type": "filesystem",
      "description": "Connects the memory provider to the ResonantOS-managed Memory folder while preserving human and AI memory boundaries.",
      "requiredCapabilities": ["filesystem", "memory-provider"],
      "configScope": "user-config"
    },
    {
      "id": "ingest-provider-route",
      "name": "Ingest provider route",
      "type": "api",
      "description": "Uses provider fabric routing for archive ingest, verification, and AI Memory synthesis.",
      "requiredCapabilities": ["providers"],
      "configScope": "host-vault"
    }
  ],
  "scripts": [
    {
      "id": "archive-runtime-preflight",
      "name": "Archive runtime preflight",
      "description": "Verify the archive runtime, configured memory root, schema, and active memory provider before ingest work starts.",
      "commandRef": "archive_runtime_status",
      "runPolicy": "preflight",
      "deterministic": true,
      "requiredCapabilities": ["memory-provider", "filesystem"],
      "producesArtifacts": ["diagnostic-report"],
      "requiresHumanApproval": false
    }
  ],
  "hooks": [
    {
      "id": "before-archive-ingest-preflight",
      "event": "before-archive-ingest",
      "handlerRef": "archive-runtime-preflight",
      "requiredCapabilities": ["memory-provider", "filesystem"],
      "failurePolicy": "block"
    }
  ],
  "health": {
    "strategy": "host-command-ready"
  },
  "service": {
    "protocol": "host-command",
    "entrypoint": "archive_runtime_status",
    "healthCommand": "archive_runtime_status"
  },
  "installHooks": {
    "onInstall": "initialize-memory-provider",
    "onEnable": "activate-memory-system-slot"
  },
  "compatibility": {
    "shellVersion": "^0.1.0",
    "platforms": ["macOS", "linux", "windows"]
  }
}
