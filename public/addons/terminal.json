{
  "id": "addon.terminal",
  "name": "Terminal",
  "version": "0.1.0",
  "author": "Resonant Alpha",
  "category": "tool",
  "sdkVersion": "0.1.0",
  "description": "Host-mediated PTY terminal workspace for running shell sessions and TUI tools inside the ResonantOS center column.",
  "runtimeType": "local-service",
  "surfaces": [
    {
      "id": "terminal-pane",
      "type": "embedded-pane",
      "label": "Terminal",
      "description": "Open a ResonantOS-hosted terminal inside the main workspace."
    }
  ],
  "requestedCapabilities": [
    {
      "capability": "shell",
      "granted": false,
      "scope": "workspace",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "ui-embedding",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "hide-surface"
    }
  ],
  "provenance": {
    "tier": "curated-signed",
    "verificationState": "verified",
    "signed": true,
    "signer": "ResonantOS bundled catalog"
  },
  "runtimeIsolation": {
    "boundary": "host-mediated-service",
    "supportsDegradedMode": true,
    "requiresReviewedGrant": true
  },
  "grantPresets": [
    {
      "id": "workspace-terminal",
      "label": "Workspace terminal",
      "description": "Allows the Terminal add-on to render an embedded workspace and run audited shell commands from the workspace scope.",
      "grants": [
        {
          "capability": "shell",
          "granted": true,
          "scope": "workspace",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "ui-embedding",
          "granted": true,
          "scope": "system",
          "revocationBehavior": "hide-surface"
        }
      ]
    }
  ],
  "providerRequirements": {
    "sharedProfiles": [],
    "supportsPrivateCredentials": false
  },
  "archiveIntegration": {
    "readScopes": [],
    "intakeWriteScopes": [],
    "canRequestIngest": false,
    "canWriteKnowledgePages": false
  },
  "health": {
    "strategy": "host-command-ready"
  },
  "service": {
    "protocol": "host-command",
    "entrypoint": "terminal_run_command",
    "healthCommand": "terminal_status"
  },
  "tools": [
    {
      "name": "terminal.run_command",
      "description": "Run a shell command through the host-mediated Terminal add-on and return stdout, stderr, exit status, duration, and timeout state. Interactive TUI tools should use the PTY workspace.",
      "requiredCapabilities": ["shell"],
      "inputSchema": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "command": { "type": "string" },
          "cwd": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["command", "cwd", "stdout", "stderr", "exitCode", "timedOut", "durationMs"],
        "properties": {
          "command": { "type": "string" },
          "cwd": { "type": "string" },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" },
          "exitCode": { "type": "number" },
          "timedOut": { "type": "boolean" },
          "durationMs": { "type": "number" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    }
  ],
  "delegation": {
    "acceptsTasks": true,
    "taskTypes": ["system-diagnosis", "system-repair", "code-change"],
    "artifactReturnTypes": ["summary", "log", "diagnostic-report", "verification-report"],
    "defaultTargetRuntime": "terminal-service",
    "requiresHumanApprovalBeforeExecution": true,
    "notes": [
      "Terminal commands run only after shell capability grant.",
      "The Terminal workspace uses a host-mediated PTY for interactive shells and TUI tools."
    ]
  },
  "workflowBoundaries": [
    {
      "id": "host-mediated-terminal",
      "label": "Host-mediated terminal",
      "jobToBeDone": "Provide a scoped terminal workspace for diagnostics, development, and repair commands through explicit shell grants.",
      "userValue": "The human can run and inspect terminal work inside ResonantOS while shell access stays visible, auditable, and revocable.",
      "repeatability": "workflow-package",
      "owner": "engineer",
      "nonGoals": [
        "Give arbitrary hidden shell access to add-ons",
        "Run destructive commands without approval",
        "Bypass recovery command allowlists"
      ]
    }
  ],
  "skills": [
    {
      "id": "terminal-diagnostic-session",
      "name": "Terminal diagnostic session",
      "description": "Use terminal commands for bounded diagnosis and verification with explicit command, cwd, output, and risk reporting.",
      "documentPath": "docs/architecture/addon-skills/terminal/DIAGNOSTIC_SESSION.md",
      "invocation": "agent-suggested",
      "requiredCapabilities": ["shell"],
      "requiredTools": ["terminal.run_command"]
    }
  ],
  "connectors": [
    {
      "id": "local-pty",
      "name": "Local PTY",
      "type": "local-runtime",
      "description": "Connects a host-mediated shell session to the ResonantOS workspace.",
      "requiredCapabilities": ["shell", "ui-embedding"],
      "configScope": "none"
    }
  ],
  "scripts": [
    {
      "id": "terminal-command-preflight",
      "name": "Terminal command preflight",
      "description": "Verify shell grant, cwd, and command metadata before executing host-mediated terminal commands.",
      "commandRef": "terminal.run_command",
      "runPolicy": "preflight",
      "deterministic": true,
      "requiredCapabilities": ["shell"],
      "producesArtifacts": ["verification-report"],
      "requiresHumanApproval": false
    }
  ],
  "hooks": [
    {
      "id": "terminal-before-task-complete",
      "event": "before-task-complete",
      "handlerRef": "terminal-command-preflight",
      "requiredCapabilities": ["shell"],
      "failurePolicy": "block"
    }
  ],
  "installHooks": {
    "onInstall": "register-terminal-workspace",
    "onEnable": "enable-host-command-terminal"
  },
  "compatibility": {
    "shellVersion": "^0.1.0",
    "platforms": ["macOS", "linux", "windows"]
  }
}
