{
  "id": "addon.camofox-browser",
  "name": "Camofox Anti-Detection Browser",
  "version": "0.1.0",
  "author": "Resonant Alpha",
  "category": "tool",
  "sdkVersion": "0.1.0",
  "description": "Anti-detection browser interceptor using Camoufox (Firefox fork). When stealth browsing is needed for sites with bot detection (Google, Amazon, LinkedIn, CloudFlare-protected), Camofox provides an alternative browser engine that the host routes commands to transparently. The user sees one browser surface; the routing is invisible.",
  "runtimeType": "local-service",
  "surfaces": [
    {
      "id": "camofox-status",
      "type": "background-task-monitor",
      "label": "Camofox Stealth Status",
      "description": "Background indicator showing Camofox engine health, active stealth sessions, and anti-detection status."
    }
  ],
  "requestedCapabilities": [
    {
      "capability": "network",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "browser-control",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "ui-embedding",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "hide-surface"
    }
  ],
  "provenance": {
    "tier": "curated-signed",
    "verificationState": "verified",
    "signed": true,
    "signer": "ResonantOS bundled catalog"
  },
  "runtimeIsolation": {
    "boundary": "host-mediated-service",
    "supportsDegradedMode": true,
    "requiresReviewedGrant": true
  },
  "grantPresets": [
    {
      "id": "camofox-stealth-browsing",
      "label": "Stealth browsing via Camoufox",
      "description": "Allows Camofox to intercept browser commands and route them through the anti-detection Firefox engine for sites with bot protection.",
      "grants": [
        {
          "capability": "network",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "browser-control",
          "granted": true,
          "scope": "system",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "ui-embedding",
          "granted": true,
          "scope": "system",
          "revocationBehavior": "hide-surface"
        }
      ]
    }
  ],
  "providerRequirements": {
    "sharedProfiles": [],
    "supportsPrivateCredentials": false
  },
  "archiveIntegration": {
    "readScopes": [],
    "intakeWriteScopes": [],
    "canRequestIngest": false,
    "canWriteKnowledgePages": false
  },
  "health": {
    "strategy": "camofox-http-health",
    "endpoint": "http://localhost:9377/health"
  },
  "service": {
    "protocol": "http-json",
    "entrypoint": "camofox-browser/server.js",
    "healthCommand": "camofox.health",
    "shutdownCommand": "camofox.shutdown"
  },
  "tools": [
    {
      "name": "camofox.create_tab",
      "description": "Create a new stealth browser tab in a Camofox session. Optionally navigate to an initial URL. Uses anti-detection fingerprinting.",
      "requiredCapabilities": ["network", "browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "sessionKey"],
        "properties": {
          "userId": { "type": "string", "description": "Session owner identifier." },
          "sessionKey": { "type": "string", "description": "Tab group identifier." },
          "url": { "type": "string", "description": "Optional initial URL to navigate to." },
          "trace": { "type": "boolean", "description": "Enable Playwright tracing for debugging." }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["tabId", "url"],
        "properties": {
          "tabId": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.navigate",
      "description": "Navigate a Camofox stealth tab to a URL or search macro. Handles Google pre-warming and proxy rotation automatically.",
      "requiredCapabilities": ["network", "browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "tabId"],
        "properties": {
          "userId": { "type": "string" },
          "tabId": { "type": "string" },
          "url": { "type": "string" },
          "macro": { "type": "string", "description": "Search macro (e.g. @google_search)." },
          "query": { "type": "string", "description": "Search query for macro." },
          "sessionKey": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["ok", "tabId", "url"],
        "properties": {
          "ok": { "type": "boolean" },
          "tabId": { "type": "string" },
          "url": { "type": "string" },
          "refsAvailable": { "type": "boolean" },
          "googleSerp": { "type": "boolean" },
          "googleBlocked": { "type": "boolean" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.click",
      "description": "Click an element in a Camofox stealth tab by accessibility ref, CSS selector, or coordinates.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "tabId"],
        "properties": {
          "userId": { "type": "string" },
          "tabId": { "type": "string" },
          "ref": { "type": "string", "description": "Element ref ID (e.g. 'e3')." },
          "selector": { "type": "string", "description": "CSS selector fallback." },
          "coordinates": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["ok", "url"],
        "properties": {
          "ok": { "type": "boolean" },
          "url": { "type": "string" },
          "refsAvailable": { "type": "boolean" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.type",
      "description": "Type text into an element in a Camofox stealth tab by ref or selector.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "tabId", "text"],
        "properties": {
          "userId": { "type": "string" },
          "tabId": { "type": "string" },
          "ref": { "type": "string" },
          "selector": { "type": "string" },
          "text": { "type": "string" },
          "mode": { "type": "string", "description": "fill or keyboard (default: fill)." },
          "submit": { "type": "boolean", "description": "Press Enter after typing." }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["ok", "url"],
        "properties": {
          "ok": { "type": "boolean" },
          "url": { "type": "string" },
          "refsAvailable": { "type": "boolean" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.scroll",
      "description": "Scroll within a Camofox stealth tab by direction, pixel amount, or to an element ref.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "tabId"],
        "properties": {
          "userId": { "type": "string" },
          "tabId": { "type": "string" },
          "direction": { "type": "string", "description": "up or down." },
          "amount": { "type": "number", "description": "Pixels to scroll." },
          "ref": { "type": "string", "description": "Element ref to scroll into view." }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["ok", "url"],
        "properties": {
          "ok": { "type": "boolean" },
          "url": { "type": "string" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.screenshot",
      "description": "Capture a screenshot of the current Camofox stealth tab as a PNG base64 image.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "tabId"],
        "properties": {
          "userId": { "type": "string" },
          "tabId": { "type": "string" },
          "fullPage": { "type": "boolean", "description": "Capture full scrollable page." }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["screenshot"],
        "properties": {
          "screenshot": {
            "type": "object",
            "properties": {
              "data": { "type": "string", "description": "Base64-encoded PNG." },
              "mimeType": { "type": "string" }
            }
          },
          "url": { "type": "string" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": false,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.snapshot",
      "description": "Get an accessibility tree snapshot of the current Camofox stealth tab with element refs for interaction. Supports Google SERP fast-path extraction.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "tabId"],
        "properties": {
          "userId": { "type": "string" },
          "tabId": { "type": "string" },
          "format": { "type": "string", "description": "text or json (default: text)." },
          "offset": { "type": "number", "description": "Character offset for paginated retrieval." },
          "includeScreenshot": { "type": "boolean" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["url", "snapshot", "refsCount"],
        "properties": {
          "url": { "type": "string" },
          "snapshot": { "type": "string" },
          "refsCount": { "type": "number" },
          "truncated": { "type": "boolean" },
          "totalChars": { "type": "number" },
          "hasMore": { "type": "boolean" },
          "nextOffset": { "type": "number" },
          "screenshot": { "type": "object" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.close_tab",
      "description": "Close a Camofox stealth tab and clean up its resources.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "tabId"],
        "properties": {
          "userId": { "type": "string" },
          "tabId": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["ok"],
        "properties": {
          "ok": { "type": "boolean" },
          "tabId": { "type": "string" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.list_tabs",
      "description": "List all open Camofox stealth tabs for a user session.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId"],
        "properties": {
          "userId": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["tabs"],
        "properties": {
          "tabs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tabId": { "type": "string" },
                "url": { "type": "string" },
                "sessionKey": { "type": "string" }
              }
            }
          }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "camofox.import_cookies",
      "description": "Import cookies into a Camofox session for authenticated stealth browsing. Requires CAMOFOX_API_KEY to be configured.",
      "requiredCapabilities": ["network", "browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["userId", "cookies"],
        "properties": {
          "userId": { "type": "string" },
          "cookies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "value", "domain"],
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "string" },
                "domain": { "type": "string" },
                "path": { "type": "string" },
                "expires": { "type": "number" },
                "httpOnly": { "type": "boolean" },
                "secure": { "type": "boolean" },
                "sameSite": { "type": "string" }
              }
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["ok", "count"],
        "properties": {
          "ok": { "type": "boolean" },
          "userId": { "type": "string" },
          "count": { "type": "number" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": true
    }
  ],
  "delegation": {
    "acceptsTasks": true,
    "taskTypes": ["browser-inspection", "research"],
    "artifactReturnTypes": ["summary", "markdown", "log", "citation-bundle"],
    "defaultTargetRuntime": "local-service",
    "requiresHumanApprovalBeforeExecution": false,
    "notes": [
      "Use Camofox when the target site has bot detection (Google, Amazon, LinkedIn, CloudFlare-protected).",
      "For sites without bot detection, prefer the stock Resonant Browser (addon.browser).",
      "Camofox routes browser commands through a Camoufox Firefox engine with anti-fingerprinting.",
      "Cookie import requires explicit CAMOFOX_API_KEY configuration — disabled by default."
    ]
  },
  "install": {
    "mode": "detect-existing-or-install",
    "detectionTool": "camofox.list_tabs",
    "requiredCapabilities": ["network", "browser-control"],
    "requiresHumanApprovalBeforeInstall": true,
    "preservesExistingUserConfig": true,
    "credentialSetup": "none",
    "auditLogRequired": true,
    "expectedArtifacts": ["log"]
  },
  "installHooks": {
    "onInstall": "detect-or-fetch-camoufox"
  },
  "compatibility": {
    "shellVersion": "^0.1.0",
    "platforms": ["macOS", "linux"]
  }
}
