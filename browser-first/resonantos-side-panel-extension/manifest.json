{
  "manifest_version": 3,
  "name": "ResonantOS Browser Layer",
  "version": "0.1.0",
  "key": "",
  "description": "Browser-contained ResonantOS layer for Augmentor, Living Archive context, add-ons, task monitor, and approval gates.",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "history", "scripting", "sidePanel", "storage", "tabs", "webNavigation"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "side_panel": {
    "default_path": "src/side-panel.html"
  },
  "action": {
    "default_title": "Open ResonantOS"
  },
  "commands": {
    "open-augmentor-side-panel": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Open the Augmentor side panel"
    }
  }
}
