#!/usr/bin/env bash
# resonantos-bridge-host
# Native Messaging Host wrapper for the ResonantOS Browser Layer extension.
#
# Chrome spawns this script when the extension calls
#   chrome.runtime.connectNative("com.resonantos.bridge")
#
# The Native Messaging protocol uses length-prefixed JSON on stdin/stdout:
#   - Input:  4-byte little-endian uint32 length, then that many UTF-8 JSON bytes
#   - Output: 4-byte little-endian uint32 length, then that many UTF-8 JSON bytes
#
# This wrapper:
#   1. Checks whether the bridge daemon is already listening on port 47773.
#   2. If not, starts the daemon in the background.
#   3. Reads one Native Messaging request from stdin.
#   4. Proxies it to the bridge HTTP API and writes the response back.
#   5. Exits (Chrome manages the host process lifecycle).

set -euo pipefail

BRIDGE_PORT=47773
BRIDGE_URL="http://127.0.0.1:${BRIDGE_PORT}"
BRIDGE_DAEMON_PATH="$(dirname "$0")/../host/bridge-daemon.mjs"
LOG_FILE="${TMPDIR:-/tmp}/resonantos-bridge-host.log"

# ---------------------------------------------------------------------------
# Logging (to file only — stdout is reserved for Native Messaging protocol)
# ---------------------------------------------------------------------------
log() {
  echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $*" >> "${LOG_FILE}" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Native Messaging helpers
# ---------------------------------------------------------------------------

# Read exactly N bytes from stdin into variable $NM_DATA
read_bytes() {
  local n=$1
  NM_DATA="$(dd bs=1 count="${n}" 2>/dev/null | cat)"
}

# Read a Native Messaging message (4-byte length prefix + JSON body)
# Sets global $NM_MSG to the JSON string
read_nm_message() {
  # Read 4-byte little-endian length
  local b0 b1 b2 b3
  b0=$(dd bs=1 count=1 2>/dev/null | od -An -tu1 | tr -d ' \n')
  b1=$(dd bs=1 count=1 2>/dev/null | od -An -tu1 | tr -d ' \n')
  b2=$(dd bs=1 count=1 2>/dev/null | od -An -tu1 | tr -d ' \n')
  b3=$(dd bs=1 count=1 2>/dev/null | od -An -tu1 | tr -d ' \n')

  # Handle empty/EOF
  if [ -z "${b0}" ]; then
    NM_MSG=""
    return
  fi

  b0=${b0:-0}; b1=${b1:-0}; b2=${b2:-0}; b3=${b3:-0}
  local length=$(( b0 + b1*256 + b2*65536 + b3*16777216 ))

  if [ "${length}" -le 0 ] || [ "${length}" -gt 1048576 ]; then
    log "Invalid message length: ${length}"
    NM_MSG=""
    return
  fi

  NM_MSG="$(dd bs=1 count="${length}" 2>/dev/null | cat)"
  log "Received NM message (${length} bytes): ${NM_MSG}"
}

# Write a Native Messaging response: 4-byte LE length prefix + JSON body
write_nm_message() {
  local json="$1"
  local length=${#json}

  # Write 4-byte little-endian length to stdout using printf
  local b0=$(( length & 0xFF ))
  local b1=$(( (length >> 8) & 0xFF ))
  local b2=$(( (length >> 16) & 0xFF ))
  local b3=$(( (length >> 24) & 0xFF ))
  printf "\\x$(printf '%02x' $b0)\\x$(printf '%02x' $b1)\\x$(printf '%02x' $b2)\\x$(printf '%02x' $b3)"
  printf '%s' "${json}"
}

# ---------------------------------------------------------------------------
# Bridge health check
# ---------------------------------------------------------------------------
bridge_is_running() {
  curl -sf --max-time 1 "${BRIDGE_URL}/health" > /dev/null 2>&1
}

# ---------------------------------------------------------------------------
# Start bridge daemon if not running
# ---------------------------------------------------------------------------
ensure_bridge_running() {
  if bridge_is_running; then
    log "Bridge already running on port ${BRIDGE_PORT}."
    return 0
  fi

  log "Bridge not detected. Attempting to start ${BRIDGE_DAEMON_PATH}..."

  if [ ! -f "${BRIDGE_DAEMON_PATH}" ]; then
    log "ERROR: bridge-daemon.mjs not found at ${BRIDGE_DAEMON_PATH}"
    return 1
  fi

  # Start daemon in background, detached from this process
  nohup node "${BRIDGE_DAEMON_PATH}" \
    >> "${LOG_FILE}" 2>&1 &
  local daemon_pid=$!
  log "Bridge daemon started with PID ${daemon_pid}."

  # Wait up to 5 seconds for it to become healthy
  local attempts=0
  while [ ${attempts} -lt 10 ]; do
    sleep 0.5
    if bridge_is_running; then
      log "Bridge healthy after $((attempts * 500))ms."
      return 0
    fi
    attempts=$((attempts + 1))
  done

  log "ERROR: Bridge did not become healthy within 5 seconds."
  return 1
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
log "resonantos-bridge-host started (PID $$)"

# Ensure bridge is up
if ! ensure_bridge_running; then
  # Send error response to extension and exit
  ERROR_JSON='{"ok":false,"error":"Bridge daemon could not be started. Check logs at '"${LOG_FILE}"'"}'
  write_nm_message "${ERROR_JSON}"
  log "Sent error response to extension."
  exit 1
fi

# Read one Native Messaging request
read_nm_message

if [ -z "${NM_MSG}" ]; then
  log "Empty or EOF message — exiting."
  RESPONSE='{"ok":true,"status":"healthy","bridge":"'"${BRIDGE_URL}"'","note":"Empty NM message received."}'
  write_nm_message "${RESPONSE}"
  exit 0
fi

# Extract the "type" field from the JSON to route the request
MSG_TYPE="$(echo "${NM_MSG}" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('type','health'))" 2>/dev/null || echo "health")"
log "Message type: ${MSG_TYPE}"

case "${MSG_TYPE}" in
  health)
    # Health check — return bridge status without forwarding
    HEALTH_JSON="$(curl -sf --max-time 2 "${BRIDGE_URL}/health" 2>/dev/null || echo '{"status":"error"}')"
    RESPONSE="{\"ok\":true,\"bridge\":\"${BRIDGE_URL}\",\"health\":${HEALTH_JSON}}"
    ;;
  *)
    # Forward the request body to the bridge HTTP API
    ENDPOINT="${BRIDGE_URL}/nm/${MSG_TYPE}"
    HTTP_RESPONSE="$(echo "${NM_MSG}" | curl -sf --max-time 10 \
      -X POST "${ENDPOINT}" \
      -H "Content-Type: application/json" \
      --data-binary @- 2>/dev/null || echo '{"ok":false,"error":"Bridge request failed"}')"
    RESPONSE="${HTTP_RESPONSE}"
    ;;
esac

log "Sending response: ${RESPONSE}"
write_nm_message "${RESPONSE}"
log "resonantos-bridge-host exiting cleanly."
exit 0
