{
  "name": "resonantos-vnext",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1430 --strictPort",
    "build": "tsc && vite build --target es2022",
    "preview": "vite preview",
    "test": "vitest run",
    "memory-service": "node examples/living-archive-memory-service.mjs",
    "test:living-archive-mcp": "node --test examples/living-archive-mcp.test.mjs",
    "test:living-archive-memory-service": "node --test examples/living-archive-memory-service.test.mjs",
    "test:browser-host": "node --test addons/resonant-browser-host/test/*.test.mjs",
    "test:browser-first": "node --test browser-first/test/*.test.mjs",
    "test:browser-first-live": "node browser-first/test/agent-control-live.mjs",
    "browser-first:dev": "npm run browser-native:build:required && node browser-first/host/run-browser-first.mjs",
    "browser-first:install": "npm run browser-native:build:required && node scripts/install-browser-first-app.mjs",
    "test:electron-host": "node --test electron-host/test/*.test.mjs",
    "electron-host:smoke": "node electron-host/run-smoke.mjs",
    "electron-host:rust-ipc": "node electron-host/rust-core-ipc-smoke.mjs",
    "electron:dev": "npm run build && node electron-host/run-product.mjs",
    "electron:smoke": "npm run build && node electron-host/run-product-smoke.mjs",
    "test:browser-native": "node --test addons/resonant-browser-native/test/*.test.mjs",
    "health": "node scripts/health-check.mjs",
    "test:health": "node --test --test-concurrency=1 scripts/health-check.test.mjs",
    "engineer:prompt": "node scripts/engineer-runner.mjs prompt",
    "engineer:verify": "node scripts/engineer-runner.mjs verify",
    "test:engineer-runner": "node --test scripts/engineer-runner.test.mjs",
    "browser-native:cef:plan": "node addons/resonant-browser-native/scripts/fetch-cef.mjs",
    "browser-native:build": "node scripts/build-native-browser.mjs",
    "browser-native:build:required": "node scripts/build-native-browser.mjs --required",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run browser-native:build && tauri build"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^5.0.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
