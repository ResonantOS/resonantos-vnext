# ResonantOS vNext API Server — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── Required ────────────────────────────────────────────────────────────────

# OpenAI API key — used server-side only, never sent to clients
OPENAI_API_KEY=sk-proj-...

# JWT signing secret — MUST be at least 32 bytes of random hex
# Generate with: openssl rand -hex 32
JWT_SECRET=<run: openssl rand -hex 32>

# Set to "production" to disable stack traces in error responses
NODE_ENV=production

# Port to listen on (nginx proxies /api/ → this port)
PORT=5100

# ─── Optional Tuning ─────────────────────────────────────────────────────────

# JWT token TTL (default: 24h)
JWT_EXPIRES_IN=24h

# Daily message cap per user (default: 50)
DAILY_MSG_LIMIT=50

# Max tokens per OpenAI request (default: 4000)
MAX_TOKENS_PER_REQ=4000

# SQLite database file path
DB_PATH=/var/www/ros-server/data/ros.db

# Allowed CORS origin (default: https://resonantclaw.com)
ALLOWED_ORIGIN=https://resonantclaw.com

# Monthly spend cap in USD — hard cutoff (default: 50)
MONTHLY_SPEND_LIMIT_USD=50
